# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different platforms or python versions,
#   feel free to ignore it.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains the resolved dependencies.
#   It's recommended to commit this.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains the resolved dependencies.
#   It's recommended to commit this.
#pdm.lock

# venv
#   Only share templates; local envs should be excluded
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

